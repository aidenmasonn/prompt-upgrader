{
  "manifest_version": 3,
  "name": "Prompt Upgrader — Memory Capture",
  "version": "1.0.0",
  "description": "Save Q&A pairs from any webpage into your Prompt Upgrader memory.",
  "permissions": ["activeTab", "contextMenus", "storage", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Prompt Upgrader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
